AI_PLATFORM_CLI_INIT=0
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=
PLATFORM_STORAGE_ROOT=./platform_projects

# Comma-separated frontend origins allowed by FastAPI CORS.
# Example:
# FRONTEND_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173

# MongoDB
MONGO_URI=
MONGO_DB=ai_platform

# Local model deploy defaults
LOCAL_DEPLOY_PORT=8001
LOCAL_DEPLOY_CMD=
LOCAL_DEPLOY_CWD=

# Optional GitHub fallback remote
GITHUB_REPO_URL=
